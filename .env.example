# ──────────────────────────────────────────────
# OpenWebUI Project — Environment Variables
# Copy this to .env and fill in your values
# ──────────────────────────────────────────────

# ── AWS / S3 ──────────────────────────────────
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=wJalr...
AWS_REGION=us-east-1
S3_BUCKET_NAME=my-bucket-name

# ── SQS (optional — enables real-time sync) ──
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/openwebui-s3-events

# ── Sync Scheduler ───────────────────────────
# How often (in seconds) the background sync runs. 0 = disabled.
SYNC_INTERVAL_SECONDS=300

# ── Frontend API base (sync-service: auth, KBs, plugins, /sync) ──
VITE_API_URL=http://localhost:8000
# When using host nginx with SSL and path prefixes (see deploy/README.md), set to:
#   VITE_API_URL=https://cpsc319.jaskiratgill.ca/api/sync

VITE_OPENWEBUI_BASE_URL=http://localhost:3000
# In production, set this to the URL where your OpenWebUI
# instance is reachable (e.g. https://chat.example.com)
VITE_OPENWEBUI_TOKEN=eyJhbGci...
VITE_OPENWEBUI_TIMEOUT_MS=120000
